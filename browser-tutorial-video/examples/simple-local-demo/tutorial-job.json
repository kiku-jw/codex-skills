{
  "title": "Browser Tutorial Video Local Demo",
  "startUrl": "./index.html",
  "outputDir": "./out/simple-local-demo",
  "viewport": {
    "width": 1280,
    "height": 720
  },
  "fps": 15,
  "zoom": 1,
  "headless": true,
  "initialWaitMs": 500,
  "finalWaitMs": 700,
  "actions": [
    {
      "type": "wait",
      "ms": 400
    },
    {
      "type": "click",
      "selector": "#features-link",
      "label": "View workflow"
    },
    {
      "type": "scroll",
      "y": 520,
      "durationMs": 900
    },
    {
      "type": "click",
      "selector": "#export",
      "label": "Export MP4"
    }
  ],
  "qa": {
    "every": 1,
    "checkpoints": [
      0
    ]
  }
}
